<instance format="XCSP3" type="CSP">
  <variables>
    <array id="x" note="x[i][j] is the value at row i and col j" size="[9][9]"> 1..9 </array>
  </variables>
  <constraints>
    <group note="constraint 1 -&gt; tous les nombres de la même ligne doivent être différents">
      <allDifferent> %... </allDifferent>
      <args> x[0][] </args>
      <args> x[1][] </args>
      <args> x[2][] </args>
      <args> x[3][] </args>
      <args> x[4][] </args>
      <args> x[5][] </args>
      <args> x[6][] </args>
      <args> x[7][] </args>
      <args> x[8][] </args>
    </group>
    <group note="constraint 2 -&gt; tous les nombres de la même colonne doivent être différents">
      <allDifferent> %... </allDifferent>
      <args> x[][0] </args>
      <args> x[][1] </args>
      <args> x[][2] </args>
      <args> x[][3] </args>
      <args> x[][4] </args>
      <args> x[][5] </args>
      <args> x[][6] </args>
      <args> x[][7] </args>
      <args> x[][8] </args>
    </group>
    <group note="constraint 3 -&gt; tous les nombres dans les carrés doivent être différents">
      <allDifferent> %... </allDifferent>
      <args> x[0..2][0..2] </args>
      <args> x[0..2][3..5] </args>
      <args> x[0..2][6..8] </args>
      <args> x[3..5][0..2] </args>
      <args> x[3..5][3..5] </args>
      <args> x[3..5][6..8] </args>
      <args> x[6..8][0..2] </args>
      <args> x[6..8][3..5] </args>
      <args> x[6..8][6..8] </args>
    </group>
    <instantiation note="constraint 4 -&gt; toutes les cases déjà remplies du tableau">
      <list> x[0][1] x[0][4] x[0][7] x[1][2] x[1][5] x[1][8] x[2][0] x[2][4..5] x[2][7] x[3][2..4] x[3][8] x[4][2] x[4][5..6] x[4][8] x[5][0] x[5][4] x[5][6..8] x[6][1] x[6][5] x[6][7..8] x[7][0] x[7][3] x[7][5] x[7][8] x[8][1] x[8][4] x[8][6..7] </list>
      <values> 3 5 9 5 8 1 6 7 1 2 7 2 9 3 2 4 7 9 4 1 2 5 6 7 9 8 2 8 1 7 4 2 3 1 6 </values>
    </instantiation>
  </constraints>
</instance>
